---
import "../styles/globals.css";
import { ThemeToggle } from "../components/ThemeToggle";

interface Props {
  title?: string;
}

const { title = "UH Course Search" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="University of Hawaii course search" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <script is:inline>
      // Apply theme before first paint to avoid flash
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        if (stored === "dark" || (!stored && prefersDark)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    <header class="sticky top-0 z-40 border-b bg-background/95 backdrop-blur">
      <div class="mx-auto flex h-14 max-w-7xl items-center justify-between px-4 sm:px-6">
        <div class="flex items-center gap-2">
          <span class="text-lg font-semibold tracking-tight">UH Course Search</span>
          <span class="hidden text-xs text-muted-foreground sm:inline">
            Banner SSB9
          </span>
        </div>
        <ThemeToggle client:load />
      </div>
    </header>

    <main class="mx-auto max-w-7xl px-4 py-8 sm:px-6">
      <slot />
    </main>

    <footer class="border-t py-4 text-center text-xs text-muted-foreground">
      Data sourced from the University of Hawaii Student Information System.
    </footer>
  </body>
</html>
