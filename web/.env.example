# Base URL for the UH Banner SSB9 Student Information System
# Copy this file to .env and adjust if needed.
SIS_BASE_URL=https://www.sis.hawaii.edu:9234/StudentRegistrationSsb

CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# Cloudflare D1 persistent data layer (see docs/plans/d1-persistence.md)
# database_id of the `uh_sis` D1 database (from `wrangler d1 create uh_sis`).
D1_DATABASE_ID=
# "local" (default outside production) reads the wrangler local D1 file under
# .wrangler/state; "remote" uses the D1 REST API and needs the three vars above.
D1_MODE=local

# Shared secret guarding the /api/admin/* ingestion + seat-refresh routes.
# Sent as the `x-admin-secret` header. Generate with: openssl rand -hex 32
ADMIN_SECRET=

# Cache-on-miss toggles (the only live-Banner calls on a user request).
# DYNAMIC_SYNC=0 disables the demand-driven page cache for un-backfilled terms —
# the live, sort-aware per-page section fetch on /api/search (also gates the
# lazy subject-menu enumeration); SECTION_LAZY_FETCH=0 disables lazy section detail
# (/api/section); COURSE_TEXT_LAZY=0 disables lazy course text — description /
# prerequisites / corequisites — on first panel view (/api/course). All default on.
# DYNAMIC_SYNC=1
# SECTION_LAZY_FETCH=1
# COURSE_TEXT_LAZY=1

# Tier B2 rolling cap: stalest detail CRNs refreshed per term per hourly run (default 250).
# REFRESH_ROLLING_DETAIL_CRNS=250

# Dev-log source tags: [DB] = served from D1, [SIS] = live Banner call.
# Set LOG_SOURCE=0 to silence them.
# LOG_SOURCE=1